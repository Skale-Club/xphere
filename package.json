  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 4267",
    "build:widget": "esbuild src/widget/index.ts --bundle --minify --platform=browser --format=iife --target=es2017 --outfile=public/widget.js",
    "build:reviews-widget": "esbuild src/reviews-widget/index.ts --bundle --minify --platform=browser --format=iife --target=es2017 --outfile=public/reviews-widget.js",
    "build": "npm run build:widget && npm run build:reviews-widget && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "vercel:pull": "vercel pull --yes --environment preview --scope skaleclub",
    "vercel:build": "vercel build --yes --scope skaleclub",
    "vercel:build:prod": "vercel build --prod --yes --scope skaleclub",
    "vercel:list": "vercel ls --scope skaleclub",
    "vercel:deploy": "vercel deploy --yes --scope skaleclub",
    "vercel:deploy:prod": "vercel deploy --prod --yes --scope skaleclub"
