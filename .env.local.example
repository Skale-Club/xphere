# ── Database (Supabase) ───────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# CLI only — used by: npx supabase db push
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=your-password

# ── Security ──────────────────────────────────────────────────────────────────
# Must never change after first deploy (openssl rand -hex 32)
ENCRYPTION_SECRET=your-32-byte-hex-secret

# ── App ───────────────────────────────────────────────────────────────────────
# Email allowed to access /settings/platform
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
# Chat session storage (local: redis://localhost:6379 | prod: Upstash URL)
REDIS_URL=redis://localhost:6379
# Canonical public origin (see src/lib/site-url.ts). Inlined at build time
# (Dockerfile build arg) — used for OAuth callbacks, sitemap/robots, and
# metadata. Leave unset locally to fall back to the request host.
NEXT_PUBLIC_SITE_URL=http://localhost:4267

# ── AI provider ───────────────────────────────────────────────────────────────
# Intentionally NOT in env. Platform AI keys are managed by the super admin at
# /settings/platform (encrypted in the platform_settings table). The resolver
# tries (in order):
#   1. Org-stored OpenRouter key (Integrations → OpenRouter)
#   2. Platform OpenRouter key (super admin)
#   3. Org-stored Anthropic key (Integrations → Anthropic)
#   4. Platform Anthropic key (super admin)
# Do NOT add OPENROUTER_API_KEY or ANTHROPIC_API_KEY here.

# ── Integrations ──────────────────────────────────────────────────────────────
# Vapi — platform-level webhook secret (Vapi Dashboard → Webhooks)
# TODO: move to /settings/platform
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
# Meta — platform app credentials (Meta for Developers → App Settings → Basic)
# META_VERIFY_TOKEN: random string you set in Meta App Dashboard → Webhooks → Verify Token
# TODO: move to /settings/platform
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-random-verify-token

# Google Contacts + Calendar OAuth
# Obtain from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: https://xphere.app/api/integrations/google/callback, https://xphere.app/api/google/calendar-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Ads OAuth (separate OAuth client — dedicated to adwords scope)
# Obtain from: Google Cloud Console → Create a NEW OAuth 2.0 Client ID
# Authorized redirect URIs: https://xphere.app/api/ads/google/callback
# Required API: Google Ads API (enable in APIs & Services → Library)
# Required: GOOGLE_ADS_DEVELOPER_TOKEN from Google Ads Manager Account
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Notion OAuth for Global Knowledge (public connection, read-content capability)
# Redirect URI: https://xphere.app/api/notion/callback
# Webhook URL: https://xphere.app/api/notion/webhook
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_WEBHOOK_VERIFICATION_TOKEN=

# Authenticates /api/cron/* calls from GitHub Actions or the host scheduler.
CRON_SECRET=

# ── Stripe billing (org-level subscriptions — migration 1109) ─────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret.
# Endpoint URL: https://xphere.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Server-side price mapping. One var per plan key (STRIPE_PRICE_<KEY>). The client
# only ever sends the lowercase key (e.g. "pro"); the server resolves the price.
# Plans are defined in src/lib/billing/catalog.ts (features, limits, credits).
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# One-time Copilot credit top-up packages (mode=payment). One var per package.
# STRIPE_PRICE_CREDITS_SMALL=price_...
# STRIPE_PRICE_CREDITS_MEDIUM=price_...
# STRIPE_PRICE_CREDITS_LARGE=price_...
# Global kill-switch for billing ENFORCEMENT (paywall + plan/credit gating).
# Leave unset/false until plans are live in Stripe and existing orgs are
# provisioned/grandfathered (see plan Phase 7). Set to 'true' to enforce.
# BILLING_ENFORCEMENT_ENABLED=false

# ── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate a fresh pair with: npx web-push generate-vapid-keys
# The public key is also embedded as a fallback in src/lib/push/vapid.ts and
# the push-sender Supabase Edge Function (supabase/functions/push-sender/index.ts).
# Override here if you rotate keys.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BMEcSTxVVttfJ9u9yWgHDgO_BQOTKoh4tvGIM8QlzrhjDSThw3xAitj6l6SySKlEPdiag7BCORb_VZ_Hi6BwNY0
# VAPID_PRIVATE_KEY is only needed by the push-sender Edge Function (set as Supabase secret).

# ── Prospects integrations (Xmail outreach, Xpot field visits) ────────────────
# Outbound: Xphere pushes selected prospects to these services. Leave blank to
# hide the matching bulk action. Inbound engagement/visit webhooks authenticate
# with an Xphere API key (Settings → API Keys), so no secret is needed here.
# Xmail (email outreach engine — skaleclub-mail):
XMAIL_API_URL=
XMAIL_USER_ID=
XMAIL_ORG_ID= # the Xmail organization id that owns the outreach data
XMAIL_SERVICE_KEY= # machine-to-machine credential required on Xmail's /api/outreach/ routes
XMAIL_ESTIMATE_FROM= # optional; default sending inbox for prospect_send_message (MCP). Defaults to info@skale.club
# Xpot (B2B field-sales app):
XPOT_API_URL=
XPOT_API_KEY=

# ── Admin panel (/settings/platform) — not in env ─────────────────────────────
# GOOGLE_PLACES_API_KEY  →  stored encrypted in DB, managed via UI
