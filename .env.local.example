# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ENCRYPTION_SECRET=your-32-byte-hex-secret

# Supabase CLI (pooler connection, Transaction mode port 6543)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=your-password

# Platform admin — email allowed to access /settings/platform
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com

# Vapi — platform-level webhook secret (per-org API key managed via /integrations)
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# Meta (Facebook / Instagram OAuth) — Meta Developer App credentials
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Redis — chat session storage
# Local dev: start redis-server and use redis://localhost:6379
# Production: Upstash Redis URL from dashboard
REDIS_URL=redis://localhost:6379

# Meta Webhook (Phase 11+)
# META_APP_SECRET: From Meta App Dashboard → App Settings → Basic → App Secret
# META_VERIFY_TOKEN: A random string you generate (e.g. openssl rand -hex 16).
#   Set the same value in Meta App Dashboard → Webhooks → Callback URL → Verify Token.
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-random-verify-token
