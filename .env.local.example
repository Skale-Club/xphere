# ── Database (Supabase) ───────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# CLI only — used by: npx supabase db push
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=your-password

# ── Security ──────────────────────────────────────────────────────────────────
# Must never change after first deploy (openssl rand -hex 32)
ENCRYPTION_SECRET=your-32-byte-hex-secret

# ── App ───────────────────────────────────────────────────────────────────────
# Email allowed to access /settings/platform
PLATFORM_ADMIN_EMAIL=admin@yourdomain.com
# Chat session storage (local: redis://localhost:6379 | prod: Upstash URL)
REDIS_URL=redis://localhost:6379

# ── AI provider ───────────────────────────────────────────────────────────────
# Intentionally NOT in env. Platform AI keys are managed by the super admin at
# /settings/platform (encrypted in the platform_settings table). The resolver
# tries (in order):
#   1. Org-stored OpenRouter key (Integrations → OpenRouter)
#   2. Platform OpenRouter key (super admin)
#   3. Org-stored Anthropic key (Integrations → Anthropic)
#   4. Platform Anthropic key (super admin)
# Do NOT add OPENROUTER_API_KEY or ANTHROPIC_API_KEY here.

# ── Cloudflare Turnstile (optional — login captcha) ───────────────────────────
# If unset, captcha verification is skipped (see src/lib/auth/verify-turnstile.ts).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Integrations ──────────────────────────────────────────────────────────────
# Vapi — platform-level webhook secret (Vapi Dashboard → Webhooks)
# TODO: move to /settings/platform
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
# Meta — platform app credentials (Meta for Developers → App Settings → Basic)
# META_VERIFY_TOKEN: random string you set in Meta App Dashboard → Webhooks → Verify Token
# TODO: move to /settings/platform
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-random-verify-token

# Google Contacts OAuth (Phase 27)
# Obtain from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe billing (org-level subscriptions — migration 1109) ─────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret.
# Endpoint URL: https://xphere.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Server-side price mapping. One var per plan key (STRIPE_PRICE_<KEY>). The client
# only ever sends the lowercase key (e.g. "pro"); the server resolves the price.
# STRIPE_PRICE_PRO=price_...

# ── Admin panel (/settings/platform) — not in env ─────────────────────────────
# GOOGLE_PLACES_API_KEY  →  stored encrypted in DB, managed via UI
