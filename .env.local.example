NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis — chat session storage (Phase 2+)
# Local dev: start redis-server, use redis://localhost:6379
# Production: Upstash Redis URL from dashboard
REDIS_URL=redis://localhost:6379

# Meta Webhook (Phase 11+)
# META_APP_SECRET: From Meta App Dashboard → App Settings → Basic → App Secret
# META_VERIFY_TOKEN: A random string you generate (e.g. openssl rand -hex 16).
#   Set the same value in Meta App Dashboard → Webhooks → Callback URL → Verify Token.
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-random-verify-token
